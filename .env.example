# ── Database ──────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://nova:dev_pass@localhost:5432/nova

# ── Redis ─────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── Auth ──────────────────────────────────────────────
JWT_SECRET=change_this_to_a_random_64_char_string_in_prod
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
JWT_REFRESH_TOKEN_EXPIRE_DAYS=30

# ── Storage (S3 compatible) ───────────────────────────
S3_ENDPOINT=http://localhost:9000       # MinIO en dev / Hostinger Object Storage en prod
S3_BUCKET=nova-dev
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_PUBLIC_URL=http://localhost:9000/nova-dev

# ── Email (SMTP) ──────────────────────────────────────
SMTP_HOST=smtp.hostinger.com
SMTP_PORT=587
SMTP_USER=noreply@tu-dominio.com
SMTP_PASSWORD=change_this
SMTP_FROM=Nova Fora <noreply@tu-dominio.com>

# ── Frontend ──────────────────────────────────────────
# En nova-fora-demo/.env.local:
VITE_API_BASE_URL=http://localhost:8000

# ── Observabilidad ────────────────────────────────────
SENTRY_DSN=
POSTHOG_KEY=

# ── App ───────────────────────────────────────────────
ENV=development          # development | production
APP_URL=http://localhost:5173
API_URL=http://localhost:8000
